# StreamSync Configuration
# Required
SHARE_TOKEN=change-this-secure-token-min-32-chars
ADMIN_SECRET=change-this-admin-password

# Optional
ROOM_NAME=MyStream
MAX_PEERS=50
MAX_UPLOAD_SIZE=100MB

# Domain (for HTTPS)
DOMAIN=your-domain.com
EMAIL=admin@your-domain.com

# Ports (do not change)
PORT=3001