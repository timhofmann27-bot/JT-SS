# JT-MP3 Environment Configuration
# Copy this file to .env and fill in your own secure values
# NEVER commit .env to version control

# Required: Secret for accessing the music library
SHARE_TOKEN=change-this-to-a-long-random-string

# Required: Secret for admin initialization
ADMIN_SECRET=change-this-to-a-long-random-string

# Required: Secret for JWT session token signing
JWT_SECRET=change-this-to-a-long-random-string

# Server port (default: 3001)
PORT=3001

# Room name (default: JT-MP3)
ROOM_NAME=JT-MP3

# Media directory (default: ./media)
MEDIA_DIR=./media

# Data directory (default: ./data)
DATA_DIR=./data

# Max upload size (default: 100MB)
MAX_UPLOAD_SIZE=100MB

# Max connected peers (default: 10)
MAX_PEERS=10

# Bind host (default: 127.0.0.1 - use reverse proxy for external access)
BIND_HOST=127.0.0.1
